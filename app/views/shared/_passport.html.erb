<section id="passport" data-controller="passport">
  <div class="passport-content">
    <div class="section-label reveal">Your Journey</div>
    <h2 class="section-title reveal reveal-delay-1">Bagel <em>Passport</em></h2>
    <p class="story-text reveal reveal-delay-2">
      Collect all 8 flavors to unlock the secret 9th bagel.
      Only 0.3% of customers have completed their passport.
    </p>

    <div class="passport-card reveal reveal-delay-3">
      <div class="stamp-grid" data-passport-target="stampGrid">
        <%# Generated by JS %>
      </div>

      <div class="passport-progress">
        <div class="passport-progress-label">
          <span>Progress</span>
          <span data-passport-target="count">3 / 8</span>
        </div>
        <div class="passport-bar">
          <div class="passport-fill" data-passport-target="fill"></div>
        </div>
      </div>
    </div>
  </div>
</section>
