  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "convex": "^1.32.0",
    "esbuild": "^0.27.3",
    "tailwindcss": "^4.2.1"
  }
}
